#!/usr/bin/env python3
"""ops — 任务聚合平台"""

import subprocess
import sys
from pathlib import Path

SYNC_DIR = Path.home() / ".local" / "share" / "repos"

COMMANDS = [
    f'curl -fsSL https://raw.githubusercontent.com/qiao-925/clone-faster/main/clone_faster.py | python3 - --output {SYNC_DIR}',
    f'make -C {SYNC_DIR}/claude-session-sync sync',
]

for cmd in COMMANDS:
    subprocess.run(cmd, shell=True)
    print()
