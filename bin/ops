#!/usr/bin/env bash
# ops — 任务聚合平台
set -euo pipefail

SYNC_DIR="${OPS_SYNC_DIR:-$HOME/.local/share/repos}"

COMMANDS=(
    "curl -fsSL https://raw.githubusercontent.com/qiao-925/clone-faster/main/clone_faster.py | python3 - --output $SYNC_DIR"
    "make -C $SYNC_DIR/claude-session-sync sync"
)

cmd_sync() {
    for cmd in "${COMMANDS[@]}"; do
        eval "$cmd"
        echo ""
    done
}

case "${1:-sync}" in
    sync) cmd_sync ;;
    *)    echo "用法: ops [sync]" ;;
esac
